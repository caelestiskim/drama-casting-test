{
  "name": "mock-ai-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "ln -sf ../lightningcss-darwin-arm64/lightningcss.darwin-arm64.node node_modules/lightningcss/lightningcss.darwin-arm64.node 2>/dev/null || true",
    "dev": "NODE_OPTIONS=--max-old-space-size=1024 next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=1024 next build",
    "start": "next start",
    "_memo": "NODE_OPTIONS 메모리 제한 필수 — M4 16GB + Turbopack 조합에서 제한 없으면 시스템 크래시",
    "lint": "eslint",
    "build:cf": "next build && npx @cloudflare/next-on-pages",
    "preview:cf": "opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && wrangler pages deploy"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@polar-sh/checkout": "^0.2.0",
    "html-to-image": "^1.11.13",
    "lightningcss": "^1.32.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@opennextjs/cloudflare": "^1.19.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.82.2"
  }
}
